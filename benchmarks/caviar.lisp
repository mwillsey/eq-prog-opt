;; ?add.rs
(birewrite (Add ?a ?b) (Add ?b ?a))
(birewrite (Add ?a (Add ?b ?c)) (Add (Add ?a ?b) ?c))
(birewrite (Add ?a (Num 0)) ?a)
(birewrite (Mul ?a (Add ?b ?c)) (Add (Mul ?a ?b) (Mul ?a ?c)))
(birewrite (Add (Div ?a ?b) ?c) (Div (Add ?a (Mul ?b ?c)) ?b))
(birewrite (Add (Div ?x (Num 2)) (Mod ?x (Num 2))) (Div (Add ?x (Num 1)) (Num 2)))
(rewrite (Add (Mul ?x ?a) (Mul ?y ?b)) (Mul (Add (Mul ?x (Div ?a ?b)) ?y) ?b) :when (compare ?a ?b "%0"))

;; ?andor.rs
(rewrite (And ?a (Or ?b ?c)) (Or (And ?a ?b) (And ?a ?c)))
(rewrite (Or ?a (And ?b ?c)) (And (Or ?a ?b) (Or ?a ?c)))
(rewrite (Or ?x (And ?x ?y)) ?x)

;; ?and.rs
(rewrite (And ?y ?x) (And ?x ?y))
(birewrite (And ?a (And ?b ?c)) (And (And ?a ?b) ?c))
(rewrite (And (Num 1) ?x) ?x)
(rewrite (And ?x ?x) ?x)
(rewrite (And ?x (Not ?x)) (Num 0))
(rewrite (And (Eq ?x ?c0) (Eq ?x ?c1)) (Num 0) :when (compare ?c0 ?c1 "!="))
(rewrite (And (Neq ?x ?c0) (Eq ?x ?c1)) (Eq ?x ?c1) :when (compare ?c0 ?c1 "!="))
(birewrite (And (Lt ?x ?y) (Lt ?x ?z)) (Lt ?x (Min ?y ?z)))
(birewrite (And (Leq ?x ?y) (Leq ?x ?z)) (Leq ?x (Min ?y ?z)))
(rewrite (And (Lt ?y ?x) (Lt ?z ?x)) (Lt (Max ?y ?z) ?x))
(rewrite (Gt ?x (Max ?y ?z)) (And (Lt ?z ?x) (Lt ?y ?x)))
(rewrite (And (Leq ?y ?x) (Leq ?z ?x)) (Leq (Max ?y ?z) ?x))
(rewrite (Geq ?x (Max ?y ?z)) (And (Leq ?z ?x) (Leq ?y ?x)))
(rewrite (And (Lt ?c0 ?x) (Lt ?x ?c1)) (Num 0) :when (compare ?c1 ?c0 "<=+1"))
(rewrite (And (Leq ?c0 ?x) (Leq ?x ?c1)) (Num 0) :when (compare ?c1 ?c0 "<"))
(rewrite (And (Leq ?c0 ?x) (Lt ?x ?c1)) (Num 0) :when (compare ?c1 ?c0 "<="))

;; div.rs
(rewrite (Div (Num 0) ?x) (Num 0))
(rewrite (Div ?a ?a) (Num 1) :when (non-zero? ?a))
(birewrite (Div (Mul (Num -1) ?a) ?b) (Div ?a (Mul (Num -1) ?b)))
(birewrite (Mul (Num -1) (Div ?a ?b)) (Div (Mul (Num -1) ?a) ?b))
(birewrite (Div (Mul ?x ?a) ?b) (Div ?x (Div ?b ?a)) :when (compare ?b ?a "%0<"))
(birewrite (Div (Mul ?x ?a) ?b) (Mul ?x (Div ?a ?b)) :when (compare ?a ?b "%0<"))
(birewrite (Div (Add (Mul ?x ?a) ?y) ?b) (Add (Mul ?x (Div ?a ?b)) (Div ?y ?b)) :when (compare ?a ?b "%0<"))
(birewrite (Div (Add ?x ?a) ?b) (Add (Div ?x ?b) (Div ?a ?b)) :when (compare ?a ?b "%0<"))

;; eq.rs
(rewrite (Eq ?x ?y) (Eq ?y ?x))
(birewrite (Eq ?x ?y) (Eq (Sub ?x ?y) (Num 0)))
(birewrite (Eq (Add ?x ?y) ?z) (Eq ?x (Sub ?z ?y)))
(rewrite (Eq ?x ?x) (Num 1))
(birewrite (Eq (Mul ?x ?y) (Num 0)) (Or (Eq ?x (Num 0)) (Eq ?y (Num 0))))
(birewrite (Eq (Max ?x ?y) ?y) (Leq ?x ?y))
(birewrite (Eq (Min ?x ?y) ?y) (Leq ?y ?x))
(rewrite (Eq (Mul ?a ?x) ?b) (Num 0) :when (compare ?b ?a "!%0"))
(rewrite (Eq (Max ?x ?c) (Num 0)) (Num 0) :when (const-pos? ?c))
(rewrite (Eq (Max ?x ?c) (Num 0)) (Eq ?x (Num 0)) :when (const-neg? ?c))
(rewrite (Eq (Min ?x ?c) (Num 0)) (Num 0) :when (const-neg? ?c))
(rewrite (Eq (Min ?x ?c) (Num 0)) (Eq ?x (Num 0)) :when (const-pos? ?c))

;; ineq.rs
(rewrite (Neq ?x ?y) (Not (Eq ?x ?y)))

;; lt.rs
(rewrite (Gt ?x ?z) (Lt ?z ?x))
(birewrite (Lt ?x ?y) (Lt (Mul (Num -1) ?y) (Mul (Num -1) ?x)))
(rewrite (Lt ?a ?a) (Num 0))
(birewrite (Lt (Add ?x ?y) ?z) (Lt ?x (Sub ?z ?y)))
(birewrite (Lt ?z (Add ?x ?y)) (Lt (Sub ?z ?y) ?x))
(rewrite (Lt (Sub ?a ?y) ?a) (Num 1) :when (const-pos? ?y))
(rewrite (Lt (Num 0) ?y) (Num 1) :when (const-pos? ?y))
(rewrite (Lt ?y (Num 0)) (Num 1) :when (const-neg? ?y))
(rewrite (Lt (Min ?x ?y) ?x) (Lt ?y ?x))
(birewrite (Lt (Min ?z ?y) (Min ?x ?y)) (Lt ?z (Min ?x ?y)))

;; max.rs
(birewrite (Lt (Max ?z ?y) (Max ?x ?y)) (Lt (Max ?z ?y) ?x))

;; min.rs
(rewrite (Lt (Min ?z ?y) (Min ?x (Add ?y ?c0))) (Lt (Min ?z ?y) ?x) :when (const-pos? ?c0))
(birewrite (Lt (Max ?z (Add ?y ?c0)) (Max ?x ?y)) (Lt (Max ?z (Add ?y ?c0)) ?x) :when (const-pos? ?c0))
(birewrite (Lt (Min ?z (Add ?y ?c0)) (Min ?x ?y)) (Lt (Min ?z (Add ?y ?c0)) ?x) :when (const-neg? ?c0))
(rewrite (Lt (Max ?z ?y) (Max ?x (Add ?y ?c0))) (Lt (Max ?z ?y) ?x) :when (const-neg? ?c0))
(rewrite (Lt (Min ?x ?y) (Add ?x ?c0)) (Num 1) :when (const-pos? ?c0))
(rewrite (Lt (Max ?a ?c) (Min ?a ?b)) (Num 0))
(birewrite (Lt (Mul ?x ?y) ?z) (Lt ?x (Div (Sub (Add ?z ?y) (Num 1)) ?y)) :when (const-pos? ?y))
(birewrite (Lt ?y (Div ?x ?z)) (Lt (Sub (Mul (Add ?y (Num 1)) ?z) (Num 1)) ?x) :when (const-pos? ?z))
(rewrite (Lt ?a (Mod ?x ?b)) (Num 1) :when (compare ?a ?b "<=-a"))
(rewrite (Lt ?a (Mod ?x ?b)) (Num 0) :when (compare ?a ?b ">=a"))
(rewrite (Max ?a ?b) (Mul (Num -1) (Min (Mul (Num -1) ?a) (Mul (Num -1) ?b))))
(rewrite (Min ?a ?b) (Min ?b ?a))
(birewrite (Min (Min ?x ?y) ?z) (Min ?x (Min ?y ?z)))
(rewrite (Min ?x ?x) ?x)
(rewrite (Min (Max ?x ?y) ?x) ?x)
(birewrite (Min (Max ?x ?y) (Max ?x ?z)) (Max (Min ?y ?z) ?x))
(birewrite (Min (Max (Min ?x ?y) ?z) ?y) (Min (Max ?x ?z) ?y))
(birewrite (Min (Add ?a ?b) ?c) (Add (Min ?b (Sub ?c ?a)) ?a))
(birewrite (Add (Min ?x ?y) ?z) (Min (Add ?x ?z) (Add ?y ?z)))
(rewrite (Min ?x (Add ?x ?a)) ?x :when (const-pos? ?a))
(birewrite (Min ?x (Add ?x ?a)) (Add ?x ?a) :when (const-neg? ?a))
(birewrite (Mul (Min ?x ?y) ?z) (Min (Mul ?x ?z) (Mul ?y ?z)) :when (const-pos? ?z))
(birewrite (Mul (Min ?x ?y) ?z) (Max (Mul ?x ?z) (Mul ?y ?z)) :when (const-neg? ?z))
(birewrite (Div (Min ?x ?y) ?z) (Min (Div ?x ?z) (Div ?y ?z)) :when (const-pos? ?z))
(birewrite (Div (Max ?x ?y) ?z) (Min (Div ?x ?z) (Div ?y ?z)) :when (const-neg? ?z))
(rewrite (Min (Max ?x ?c0) ?c1) ?c1 :when (compare ?c1 ?c0 "<="))
(birewrite (Min (Mul (Div ?x ?c0) ?c0) ?x) (Mul (Div ?x ?c0) ?c0) :when (const-pos? ?c0))
(rewrite (Min (Mod ?x ?c0) ?c1) (Mod ?x ?c0) :when (compare ?c1 ?c0 ">=a-1"))
(rewrite (Min (Mod ?x ?c0) ?c1) ?c1 :when (compare ?c1 ?c0 "<=-a+1"))
(birewrite (Min (Max ?x ?c0) ?c1) (Max (Min ?x ?c1) ?c0) :when (compare ?c0 ?c1 "<="))
(birewrite (Lt (Min ?y ?c0) ?c1) (Or (Lt ?y ?c1) (Lt ?c0 ?c1)))
(birewrite (Lt (Max ?y ?c0) ?c1) (And (Lt ?y ?c1) (Lt ?c0 ?c1)))
(birewrite (Lt ?c1 (Max ?y ?c0)) (Or (Lt ?c1 ?y) (Lt ?c1 ?c0)))
(birewrite (Min (Mul ?x ?a) ?b) (Mul (Min ?x (Div ?b ?a)) ?a) :when (compare ?b ?a "%0<"))
(birewrite (Min (Mul ?x ?a) (Mul ?y ?b)) (Mul (Min ?x (Mul ?y (Div ?b ?a))) ?a) :when (compare ?b ?a "%0<"))
(birewrite (Min (Mul ?x ?a) ?b) (Mul (Max ?x (Div ?b ?a)) ?a) :when (compare ?b ?a "%0>"))
(birewrite (Min (Mul ?x ?a) (Mul ?y ?b)) (Mul (Max ?x (Mul ?y (Div ?b ?a))) ?a) :when (compare ?b ?a "%0>"))

;; modulo.rs
(rewrite (Mod (Num 0) ?x) (Num 0))
(rewrite (Mod ?x ?x) (Num 0))
(rewrite (Mod ?x (Num 1)) (Num 0))
(birewrite (Mod ?x ?c1) (Mod (Add ?x ?c1) ?c1) :when (compare ?c1 ?x "<=a"))
(birewrite (Mod ?x ?c1) (Mod (Sub ?x ?c1) ?c1) :when (compare ?c1 ?x "<=a"))
(birewrite (Mod (Mul ?x (Num -1)) ?c) (Mul (Num -1) (Mod ?x ?c)))
(birewrite (Mod (Sub ?x ?y) (Num 2)) (Mod (Add ?x ?y) (Num 2)))
(rewrite (Mod (Add (Mul ?x ?c0) ?y) ?c1) (Mod ?y ?c1) :when (compare ?c0 ?c1 "%0"))
(rewrite (Mod (Mul ?c0 ?x) ?c1) (Num 0) :when (compare ?c0 ?c1 "%0"))

;; mul.rs
(rewrite (Mul ?a ?b) (Mul ?b ?a))
(birewrite (Mul ?a (Mul ?b ?c)) (Mul (Mul ?a ?b) ?c))
(rewrite (Mul ?a (Num 0)) (Num 0))
(birewrite (Mul ?a (Num 1)) ?a)
(birewrite (Mul (Div ?a ?b) ?b) (Sub ?a (Mod ?a ?b)))
(birewrite (Mul (Max ?a ?b) (Min ?a ?b)) (Mul ?a ?b))
(rewrite (Div (Mul ?y ?x) ?x) ?y)
(birewrite (Leq ?x ?y) (Not (Lt ?y ?x)))
(rewrite (Geq ?x ?y) (Not (Lt ?x ?y)))

;; not.rs
(rewrite (Not (Eq ?x ?y)) (Neq ?x ?y))
(rewrite (Not (Not ?x)) ?x)

;; or.rs
(birewrite (Or ?x ?y) (Not (And (Not ?x) (Not ?y))))
(rewrite (Or ?y ?x) (Or ?x ?y))

;; sub.rs
